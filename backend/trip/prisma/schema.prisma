generator client {
  provider = "prisma-client-js" // Fixed provider name
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Trip {
  id              String           @id @default(uuid())
  title           String
  country         String?
  description     String?
  startDate       DateTime
  endDate         DateTime
  budget          Float?
  createdBy       String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  coverImage      String?
  imageAlt        String?
  activities      Activity[]
  deadlines       Deadline[]
  destinations    Destination[]
  recommendations Recommendation[]
  members         TripMember[]
  itinerary       Itinerary[]

  @@map("trips")
}

model Itinerary {
  id        String   @id @default(cuid())
  tripId    String   // 1. Removed the @unique constraint from here
  inputHash String   // 2. Made this required (removed the ?) to use it in our unique constraint
  itinerary Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  // 3. This composite unique constraint is the magic fix
  @@unique([tripId, inputHash])
}

model TripMember {
  id         String     @id @default(cuid())
  tripId     String
  userId     String
  memberName String?
  role       MemberRole @default(MEMBER)
  joinedAt   DateTime   @default(now())
  avatar     String?
  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([tripId])
}

model Destination {
  id         String    @id @default(cuid())
  tripId     String
  name       String
  city       String
  state      String?
  country    String?
  latitude   Float?
  longitude  Float?
  startDate  DateTime?
  endDate    DateTime?
  orderIndex Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  trip       Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model Deadline {
  id        String          @id @default(cuid())
  tripId    String
  label     String
  timeLeft  String?
  progress  Int             @default(0)
  variant   DeadlineVariant @default(NORMAL)
  createdAt DateTime        @default(now())
  trip      Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model Activity {
  id        String       @id @default(cuid())
  tripId    String?
  actorName String?
  type      ActivityType
  message   String
  createdAt DateTime     @default(now())
  trip      Trip?        @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model Recommendation {
  id        String   @id @default(cuid())
  tripId    String?
  title     String
  location  String
  image     String?
  imageAlt  String?
  createdAt DateTime @default(now())
  trip      Trip?    @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

enum MemberRole {
  OWNER
  MEMBER
}

enum DeadlineVariant {
  URGENT
  NORMAL
}

enum ActivityType {
  COMMENT
  FLIGHT
  SYSTEM
}